# Sui Network
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io

# Contract Package ID (set after deploying contracts)
NEXT_PUBLIC_PACKAGE_ID=0x_YOUR_PACKAGE_ID_HERE
NEXT_PUBLIC_REGISTRY_ID=0x_YOUR_REGISTRY_OBJECT_ID
NEXT_PUBLIC_YIELD_ENGINE_ID=0x_YOUR_YIELD_ENGINE_OBJECT_ID
NEXT_PUBLIC_COMPLIANCE_ID=0x_YOUR_COMPLIANCE_REGISTRY_ID
NEXT_PUBLIC_PLATFORM_ID=0x_YOUR_PLATFORM_OBJECT_ID
NEXT_PUBLIC_CARIB_TREASURY_ID=0x_YOUR_CARIB_TREASURY_ID

# Google OAuth (for zkLogin)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_REDIRECT_URL=http://localhost:3001/auth/callback

# Shinami (Gas Station + zkLogin Prover)
SHINAMI_GAS_STATION_KEY=your_shinami_gas_station_key
SHINAMI_ZKLOGIN_KEY=your_shinami_zklogin_key

# IPFS (Pinata)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# Indexer API
NEXT_PUBLIC_INDEXER_URL=http://localhost:4000
