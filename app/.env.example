# Sui Network
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC_URL=/api/sui-rpc
SUI_RPC_URL=https://fullnode.testnet.sui.io/

# Core Contract IDs (from deploy-core.sh)
NEXT_PUBLIC_PACKAGE_ID=0x_CORE_PACKAGE_ID
NEXT_PUBLIC_ORIGINAL_PACKAGE_ID=0x_CORE_PACKAGE_ID
NEXT_PUBLIC_REGISTRY_ID=0x_REGISTRY_ID
NEXT_PUBLIC_YIELD_ENGINE_ID=0x_YIELD_ENGINE_ID
NEXT_PUBLIC_COMPLIANCE_ID=0x_COMPLIANCE_REGISTRY_ID
NEXT_PUBLIC_PLATFORM_ID=0x_PLATFORM_ID
NEXT_PUBLIC_CARIB_TREASURY_ID=0x_CARIB_TREASURY_ID
NEXT_PUBLIC_COMMODITY_REGISTRY_ID=0x_COMMODITY_REGISTRY_ID
NEXT_PUBLIC_FEE_CONVERTER_ID=0x_FEE_CONVERTER_ID
NEXT_PUBLIC_CARIB_TYPE=0x_CARIB_TYPE
NEXT_PUBLIC_CARIB_POOL_ID=0x_CARIB_POOL_ID
NEXT_PUBLIC_STAKING_CONFIG_ID=0x_STAKING_CONFIG_ID
NEXT_PUBLIC_FEE_DISCOUNT_CONFIG_ID=0x_FEE_DISCOUNT_CONFIG_ID

# Token Registry (multi-asset)
# Each commodity is a separate Sui package with its own packageId.
# ⚠️ MUST be a single JSON env var — Next.js strips dynamic process.env access client-side.
NEXT_PUBLIC_REGISTERED_TOKENS=NUTMEG
NEXT_PUBLIC_TOKEN_CONFIG={"NUTMEG":{"packageId":"0x_NUTMEG_PKG_ID","mintVault":"0x_MINT_VAULT_ID","pool":"0x_CETUS_POOL_ID"}}

# Google OAuth (for zkLogin)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_REDIRECT_URL=http://localhost:3001/auth/callback

# Shinami (Gas Station + zkLogin Prover) — server-side only
SHINAMI_GAS_STATION_KEY=your_shinami_gas_station_key
SHINAMI_ZKLOGIN_KEY=your_shinami_zklogin_key

# Platform Admin — server-side only, NEVER prefix with NEXT_PUBLIC_
# Export CLI private key: sui keytool export --key-identity YOUR_ADDRESS --json
ADMIN_PRIVATE_KEY=your_base64_private_key
# Choose any strong password for the platform admin dashboard
PLATFORM_ADMIN_KEY=your_admin_password

# Parallel analytics read model (server-side only)
INDEXER_API_URL=http://localhost:4000

# IPFS / Pinata (optional — for warehouse receipt uploads)
PINATA_JWT=your_pinata_jwt
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# CRON
CRON_SECRET=your_cron_secret_here
